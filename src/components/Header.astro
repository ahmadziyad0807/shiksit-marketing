---
import { LINKS, SITE } from "../consts";

const navItems = [
  { name: "Features", href: "/#features" },
  { name: "Pricing", href: "/pricing" },
  { name: "Contact", href: "/#contact" },
];
---

<!-- Floating glassmorphism header -->
<header class="fixed top-0 inset-x-0 z-50 px-4">
  <div class="relative mx-auto mt-4 flex max-w-6xl items-center justify-between rounded-2xl border border-gray-200/60 bg-white/70 px-4 py-3 shadow-sm backdrop-blur-xl md:px-6">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3" aria-label="Shiksit home">
      <span class="grid h-14 w-14 place-items-center rounded-xl overflow-hidden bg-white shadow-lg shadow-purple-500/20">
        <img src="/Header.png" alt="Shiksit logo" class="w-full h-full object-contain" />
      </span>
      <span class="text-3xl font-extrabold tracking-tight text-gray-900 font-sans">{SITE.name}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden gap-8 text-lg md:flex" aria-label="Main navigation">
      {navItems.map((item) => (
        <a href={item.href} class="font-semibold text-gray-800 transition-all duration-200 hover:text-purple-600 hover:scale-110 relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-purple-600 after:transition-all after:duration-300 hover:after:w-full">
          {item.name}
        </a>
      ))}
    </nav>

    <!-- CTA buttons -->
    <div class="flex items-center gap-2">
      <a
        href={LINKS.login}
        class="hidden rounded-full border border-gray-200 px-4 py-2 text-lg font-medium text-gray-700 transition-colors hover:border-purple-400 hover:text-purple-600 md:inline-block"
      >
        Log in
      </a>
      <button
        type="button"
        data-open-book-demo
        class="inline-flex items-center gap-1 rounded-full bg-gradient-to-r from-purple-600 to-pink-500 px-3 py-1.5 text-sm font-medium text-white transition-all duration-300 hover:scale-[1.05] hover:shadow-lg hover:shadow-purple-500/50 active:scale-95 shadow-sm"
      >
        Book Demo
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </button>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-button"
        class="ml-1 grid h-9 w-9 place-items-center rounded-xl border border-gray-200 text-gray-600 hover:bg-gray-50 md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 12h16"></path><path d="M4 6h16"></path><path d="M4 18h16"></path>
        </svg>
        <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true">
          <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown (sits below the pill, same width) -->
  <div
    id="mobile-menu"
    class="mx-auto hidden max-w-6xl overflow-hidden rounded-2xl border border-gray-200/60 bg-white/90 backdrop-blur-xl shadow-sm mt-2 md:hidden"
  >
    <div class="flex flex-col gap-1 p-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="rounded-xl px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors"
        >
          {item.name}
        </a>
      ))}
      <a href={LINKS.login} class="rounded-xl px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors">
        Log in
      </a>
    </div>
  </div>
</header>

<!-- Spacer so page content starts below the fixed header -->
<div class="h-20"></div>

<script>
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");

  button?.addEventListener("click", () => {
    const isHidden = menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    button.setAttribute("aria-expanded", String(!!isHidden));
  });
</script>
