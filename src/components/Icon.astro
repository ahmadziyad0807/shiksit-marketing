---
export type IconName =
  | "award"
  | "book-open"
  | "home"
  | "briefcase"
  | "dollar-sign"
  | "truck"
  | "heart"
  | "settings"
  | "credit-card"
  | "message-square"
  | "life-buoy";

interface Props {
  name: IconName;
  class?: string;
}

const { name, class: className = "w-6 h-6" } = Astro.props;

const ICONS: Record<IconName, string> = {
