---
import { CONTACT, SITE } from "../consts";

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="relative overflow-hidden bg-gray-900 text-white py-6 mt-8">
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-6 items-start">

      <div>
        <h4 class="text-xs uppercase tracking-wider mb-2 font-bold text-blue-400">Our Address</h4>
        <a
          href={CONTACT.mapUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="block text-xs text-gray-400 hover:text-blue-300 transition-colors"
          title="View on Google Maps"
        >
          {CONTACT.address.map((line) => <span class="block">{line}</span>)}
        </a>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-wider mb-2 font-bold text-purple-400">Contact Us</h4>
        <ul class="space-y-1 text-xs text-gray-400">
          <li>Phone: {CONTACT.phone}</li>
          <li>Email: {CONTACT.email}</li>
          <li>Web: {CONTACT.web}</li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-wider mb-2 font-bold text-teal-400">Product</h4>
        <ul class="space-y-1 text-xs text-gray-400">
          <li><a href="/#features" class="hover:text-white">Features</a></li>
          <li><a href="/pricing" class="hover:text-white">Pricing</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-4 pt-4 text-xs text-gray-500 flex flex-col sm:flex-row justify-between gap-1">
      <span>&copy; {currentYear} {SITE.name}. All rights reserved.</span>
    </div>
  </div>
</footer>
