---
import { CONTACT, LINKS, SITE } from "../consts";

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-gray-900 text-white py-12 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-8">
      <div>
        <h3 class="text-lg mb-4 font-bold">{SITE.name}</h3>
        <p class="text-gray-400 text-sm">{SITE.tagline}</p>
      </div>

      <div>
        <h4 class="text-sm uppercase tracking-wider mb-4 font-bold text-blue-400">Our Address</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          {CONTACT.address.map((line) => <li>{line}</li>)}
          <li class="pt-1">
            <a
              href={CONTACT.mapUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-400 hover:text-blue-300 underline inline-flex items-center gap-1"
            >
              📍 View on Map
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm uppercase tracking-wider mb-4 font-bold text-purple-400">Contact Us</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li>Phone: {CONTACT.phone}</li>
          <li>Email: {CONTACT.email}</li>
          <li>Web: {CONTACT.web}</li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm uppercase tracking-wider mb-4 font-bold text-teal-400">Product</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="/#features" class="hover:text-white">Features</a></li>
          <li><a href={LINKS.pricing} class="hover:text-white">Pricing</a></li>
          <li><a href={LINKS.freeTrial} class="hover:text-white">Start Free Trial</a></li>
          <li><a href={LINKS.login} class="hover:text-white">Log in</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 text-sm text-gray-500 flex flex-col sm:flex-row justify-between gap-2">
      <span>&copy; {currentYear} {SITE.name}. All rights reserved.</span>
      <span>Hours: {CONTACT.hours.join(" · ")}</span>
    </div>
  </div>
</footer>
