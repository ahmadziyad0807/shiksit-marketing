---
import Layout from "../layouts/Layout.astro";

const roleHighlights = [
  { emoji: "👩‍🏫", title: "Teachers", bg: "bg-yellow-100", description: "Automated grading, lesson planning, and full class management in one dashboard.", lottie: "https://assets10.lottiefiles.com/packages/lf20_myejiggj.json" },
  { emoji: "🎒", title: "Students", bg: "bg-green-100", description: "Assignments, interactive lessons, and progress tracking, built for engagement.", lottie: "https://assets9.lottiefiles.com/packages/lf20_w51pcehl.json" },
  { emoji: "🏠", title: "Parents", bg: "bg-blue-100", description: "Real-time attendance, grades, and direct messaging with teachers.", lottie: "https://assets2.lottiefiles.com/packages/lf20_tno6cg2w.json" },
  { emoji: "🎓", title: "Principal/Manager", bg: "bg-purple-100", description: "Institution-wide oversight — enrollment, staff, and performance at a glance.", lottie: "https://assets5.lottiefiles.com/packages/lf20_svy4ivvd.json" },
  { emoji: "💰", title: "Finance Admins", bg: "bg-teal-100", description: "Fee collection, invoicing, and financial reporting, fully in-platform." },
  { emoji: "🚌", title: "Transport Admins", bg: "bg-orange-100", description: "Routes, vehicles, and pickup/drop tracking for student transport." },
  { emoji: "🧑‍💼", title: "Counselors", bg: "bg-pink-100", description: "Behavioral tracking and well-being monitoring to support every student." },
  { emoji: "💡", title: "IT Admins", bg: "bg-indigo-100", description: "User provisioning, access control, and platform settings, centralized." },
];

const valueProps = [
  { icon: "💵", title: "Fixed Monthly Pricing", description: "Simple monthly billing with no hidden fees, scaled to your institution size." },
  { icon: "💬", title: "Parent Communication", description: "Keep parents engaged and updated in real time about assignments and marks." },
  { icon: "✨", title: "Assisted Onboarding", description: "Complete setup support and interactive tutorials for all administrative staff." },
];
---

<Layout>
  <div class="relative overflow-hidden">
    <div class="relative z-10">
      <img
        src="/ShiksitSystem.png"
        alt="Our Educational System Universe — Shiksit connects teachers, students, parents, principals, finance admins, transport admins, counselors, and IT admins"
        class="scroll-reveal w-full h-auto"
      />
    </div>

    <div class="hero-blob absolute top-0 left-0 right-0 h-[600px] pointer-events-none z-0 overflow-hidden">
      <!-- Main purple blob top-left -->
      <div class="absolute -top-20 -left-20 w-[480px] h-[480px] rounded-full bg-purple-400/30 blur-[90px]"></div>
      <!-- Pink blob top-right -->
      <div class="absolute -top-10 right-0 w-[420px] h-[420px] rounded-full bg-pink-400/25 blur-[80px]"></div>
      <!-- Orange accent blob center -->
      <div class="absolute top-40 left-1/2 -translate-x-1/2 w-[320px] h-[320px] rounded-full bg-orange-300/20 blur-[70px]"></div>
    </div>

    <section class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-4 z-10 overflow-hidden">
      <div class="relative z-10 flex flex-col md:flex-row items-center gap-4 md:gap-8">

        <!-- Text + CTAs — takes up available space -->
        <div class="flex-1 text-center md:text-left">
          <span
            id="hero-badge"
            class="inline-flex items-center gap-1.5 bg-purple-100 text-purple-700 font-bold text-xs py-1 px-3.5 rounded-full mb-3 shadow-sm
                   opacity-0 translate-y-4 transition-all duration-500 ease-out delay-150"
          >
            ✨ Built for Academic Institutions
          </span>

          <h1
            id="hero-heading"
            class="text-3xl md:text-5xl font-extrabold text-gray-900 leading-tight tracking-tight mb-3
                   opacity-0 translate-y-4 transition-all duration-500 ease-out delay-300"
          >
            One Platform for Educators, Administrators, Learners, and Parents
          </h1>

          <p
            id="hero-body"
            class="text-base md:text-lg text-gray-600 max-w-3xl mb-5 leading-relaxed font-medium
                   opacity-0 translate-y-4 transition-all duration-500 ease-out delay-[450ms]"
          >
            Shiksit brings attendance, grading, communication, and finance into one unified platform for
            schools, colleges, and learning centers — built to scale as your institution grows.
          </p>
        </div>

        <!-- Logo watermark behind the hero content -->
        <div
          id="hero-logo"
          class="absolute top-1/2 right-0 -translate-y-1/2 w-40 md:w-64 pointer-events-none select-none
               opacity-10 z-0"
          aria-hidden="true"
        >
          <img
            src="/logo.png"
            alt=""
            class="w-full h-auto object-contain mix-blend-multiply"
          />
        </div>

      </div>
    </section>

    <!-- Marquee trust strip -->
    <div class="relative border-y border-gray-200/60 bg-gray-50/60 py-4 overflow-hidden">
      <div class="flex gap-16">
        <div class="flex shrink-0 animate-marquee gap-16 whitespace-nowrap pr-16 text-sm uppercase tracking-widest text-gray-400 font-medium">
          {[
            "Attendance tracking",
            "AI-graded assessments",
            "Live classes",
            "Adaptive learning",
            "Parent portal",
            "Fee management",
            "Transport tracking",
            "150+ integrations",
            "Attendance tracking",
            "AI-graded assessments",
            "Live classes",
            "Adaptive learning",
            "Parent portal",
            "Fee management",
            "Transport tracking",
            "150+ integrations",
          ].map((label) => (
            <span class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-purple-500 shrink-0" aria-hidden="true">
                <path d="M20 6 9 17l-5-5"></path>
              </svg>
              {label}
            </span>
          ))}
        </div>
      </div>
    </div>

    <section id="features" class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 z-10">
      <h2 class="scroll-reveal text-2xl md:text-3xl font-bold text-gray-900 text-center mb-1">Built for every role in your institute</h2>
      <p class="scroll-reveal text-gray-600 text-center max-w-2xl mx-auto mb-6" style="animation-range: entry 0% entry 70%;">
        Every dashboard is purpose-built for the person using it — no clutter, no learning curve.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {roleHighlights.map((role, index) => (
          <div
            class={`${role.bg} scroll-reveal rounded-2xl p-4 transition-all duration-300 hover:scale-105 hover:shadow-lg hover:-translate-y-1 cursor-pointer group`}
            style={`animation-range: entry 0% entry ${60 + (index % 4) * 12}%;`}
          >
            {role.lottie ? (
              <canvas 
                class="w-12 h-12 mb-2 transition-transform duration-300 group-hover:scale-110" 
                id={`lottie-${index}`}
                data-lottie={role.lottie}
              ></canvas>
            ) : (
              <div class="text-2xl mb-2 transition-transform duration-300 group-hover:scale-110">{role.emoji}</div>
            )}
            <h3 class="font-bold text-gray-900 mb-1">{role.title}</h3>
            <p class="text-sm text-gray-700">{role.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="relative bg-gray-50 py-8 z-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl md:text-3xl font-bold text-gray-900 text-center mb-6">Why schools choose Shiksit</h2>
        <div class="grid md:grid-cols-3 gap-4">
          {valueProps.map((prop, index) => (
            <div
              class="scroll-reveal bg-white rounded-2xl p-5 shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-xl hover:border-purple-200 hover:-translate-y-2 cursor-pointer group"
              style={`animation-range: entry 0% entry ${60 + index * 15}%;`}
            >
              <div class="text-2xl mb-2 transition-transform duration-300 group-hover:rotate-12 group-hover:scale-125">{prop.icon}</div>
              <h3 class="font-bold text-gray-900 mb-1 group-hover:text-purple-600 transition-colors">{prop.title}</h3>
              <p class="text-sm text-gray-600">{prop.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center z-10">
      <h2 class="scroll-reveal text-2xl md:text-4xl font-bold text-gray-900 mb-3">Ready to see Shiksit platform in your institution?</h2>
      <p class="scroll-reveal text-gray-600 mb-6 max-w-xl mx-auto" style="animation-range: entry 0% entry 75%;">
        Request a personalized demo tailored to your educational institution.
      </p>
      <button
        type="button"
        data-open-book-demo
        class="scroll-reveal inline-flex items-center gap-2 px-8 py-3 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 text-white font-semibold shadow-sm hover:opacity-90 transition-opacity"
        style="animation-range: entry 0% entry 90%;"
      >
        Book Demo
        <span aria-hidden="true">→</span>
      </button>
    </section>
  </div>
</Layout>

<script>
  import { DotLottie } from '@lottiefiles/dotlottie-web';

  // ── Entrance animations ──────────────────────────────────────────────────
  const show = (id: string) => {
    const el = document.getElementById(id);
    if (el) {
      el.classList.remove("opacity-0", "translate-y-4");
    }
  };

  // Trigger after first paint so CSS transitions fire
  requestAnimationFrame(() => {
    show("hero-badge");
    show("hero-heading");
    show("hero-body");
  });

  // ── Parallax on scroll ───────────────────────────────────────────────────
  const blobs = document.querySelectorAll<HTMLElement>(".hero-blob > div");

  window.addEventListener("scroll", () => {
    const y = window.scrollY;
    blobs.forEach((blob, i) => {
      blob.style.transform = `translateY(${y * (0.06 + i * 0.04)}px)`;
    });
  }, { passive: true });

  // ── Initialize Lottie animations ─────────────────────────────────────────
  document.querySelectorAll('[data-lottie]').forEach((canvas) => {
    const src = canvas.getAttribute('data-lottie');
    if (src) {
      new DotLottie({
        autoplay: true,
        loop: true,
        canvas: canvas as HTMLCanvasElement,
        src: src,
      });
    }
  });
</script>
