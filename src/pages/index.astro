---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import type { IconName } from "../components/Icon.astro";

const roleHighlights: { icon: IconName; title: string; description: string }[] = [
  { icon: "award", title: "Teachers", description: "Automated grading, lesson planning, and full class management in one dashboard." },
  { icon: "book-open", title: "Students", description: "Assignments, interactive lessons, and progress tracking, built for engagement." },
  { icon: "home", title: "Parents", description: "Real-time attendance, grades, and direct messaging with teachers." },
  { icon: "briefcase", title: "Principal/Manager", description: "Institution-wide oversight: enrollment, staff, and performance at a glance." },
  { icon: "dollar-sign", title: "Finance Admins", description: "Fee collection, invoicing, and financial reporting, fully in-platform." },
  { icon: "truck", title: "Transport Admins", description: "Routes, vehicles, and pickup/drop tracking for student transport." },
  { icon: "heart", title: "Counselors", description: "Behavioral tracking and well-being monitoring to support every student." },
  { icon: "settings", title: "IT Admins", description: "User provisioning, access control, and platform settings, centralized." },
];

const valueProps: { icon: IconName; title: string; description: string }[] = [
  { icon: "credit-card", title: "Fixed Monthly Pricing", description: "Simple monthly billing with no hidden fees, scaled to your institution size." },
  { icon: "message-square", title: "Parent Communication", description: "Keep parents engaged and updated in real time about assignments and marks." },
  { icon: "life-buoy", title: "Assisted Onboarding", description: "Complete setup support and interactive tutorials for all administrative staff." },
];
---

<Layout>
  <div class="relative overflow-hidden">
    <div class="relative z-10">
      <img
        src="/ShiksitSystem.png"
        alt="Our Educational System Universe: Shiksit connects teachers, students, parents, principals, finance admins, transport admins, counselors, and IT admins"
        class="scroll-reveal w-full h-auto"
      />
    </div>

    <div class="hero-blob absolute top-0 left-0 right-0 h-[500px] pointer-events-none z-0 overflow-hidden">
      <div class="absolute -top-24 -left-24 w-[420px] h-[420px] rounded-full bg-purple-400/15 blur-[100px]"></div>
      <div class="absolute -top-16 right-0 w-[380px] h-[380px] rounded-full bg-pink-400/12 blur-[100px]"></div>
    </div>

    <section class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4 pb-6 z-10">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div class="text-center lg:text-left">
          <span
            id="hero-badge"
            class="inline-flex items-center gap-1.5 bg-purple-100 text-purple-700 font-bold text-xs py-1 px-3.5 rounded-full mb-2 shadow-sm
                   opacity-0 translate-y-4 transition-all duration-500 ease-out delay-150"
          >
            Built for Academic Institutions
          </span>

          <h1
            id="hero-heading"
            class="text-3xl md:text-5xl font-extrabold text-gray-900 leading-tight tracking-tight mb-4
                   opacity-0 translate-y-4 transition-all duration-500 ease-out delay-300"
          >
            One Platform for Educators, Administrators, Learners, and Parents
          </h1>

          <p
            id="hero-body"
            class="text-base md:text-lg text-gray-600 max-w-2xl mx-auto lg:mx-0 mb-6 leading-relaxed
                   opacity-0 translate-y-4 transition-all duration-500 ease-out delay-[450ms]"
          >
            Shiksit brings attendance, grading, communication, and finance into one unified platform for
            schools, colleges, and learning centers, built to scale as your institution grows.
          </p>
        </div>

        <div
          id="hero-video"
          class="relative w-full max-w-md mx-auto lg:max-w-none aspect-video rounded-2xl overflow-hidden shadow-lg
                 opacity-0 translate-y-4 transition-all duration-500 ease-out delay-[300ms]"
        >
          <video
            class="w-full h-full object-cover"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
          >
            <source src="/edtech-india-animation-v3.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </section>

    <section id="features" class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 z-10">
      <h2 class="scroll-reveal text-2xl md:text-3xl font-bold text-gray-900 text-center mb-1">Built for every role in your institute</h2>
      <p class="scroll-reveal text-gray-600 text-center max-w-2xl mx-auto mb-6" style="animation-range: entry 0% entry 70%;">
        Every dashboard is purpose-built for the person using it: no clutter, no learning curve.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {roleHighlights.map((role, index) => (
          <div
            class="scroll-reveal flex items-start gap-3 bg-white rounded-2xl p-4 border border-gray-100 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1 hover:border-purple-200 cursor-pointer group"
            style={`animation-range: entry 0% entry ${60 + (index % 4) * 12}%;`}
          >
            <div class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-purple-50 text-purple-600 transition-transform duration-300 group-hover:scale-110">
              <Icon name={role.icon} class="w-5 h-5" />
            </div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">{role.title}</h3>
              <p class="text-sm text-gray-600">{role.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Marquee trust strip -->
    <div class="relative border-y border-emerald-700/40 bg-gradient-to-r from-orange-500 to-emerald-500 py-4 overflow-hidden">
      <div class="flex gap-16">
        <div class="flex shrink-0 animate-marquee gap-16 whitespace-nowrap pr-16 text-sm uppercase tracking-widest text-white font-bold drop-shadow-sm">
          {[
            "Attendance tracking",
            "AI-graded assessments",
            "Live classes",
            "Adaptive learning",
            "Parent portal",
            "Fee management",
            "Transport tracking",
            "150+ integrations",
            "Attendance tracking",
            "AI-graded assessments",
            "Live classes",
            "Adaptive learning",
            "Parent portal",
            "Fee management",
            "Transport tracking",
            "150+ integrations",
          ].map((label) => (
            <span class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-white shrink-0" aria-hidden="true">
                <path d="M20 6 9 17l-5-5"></path>
              </svg>
              {label}
            </span>
          ))}
        </div>
      </div>
    </div>

    <section class="relative bg-gray-50 py-8 z-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="scroll-reveal text-2xl md:text-3xl font-bold text-gray-900 text-center mb-6">Why schools choose Shiksit</h2>
        <div class="grid md:grid-cols-3 gap-4">
          {valueProps.map((prop, index) => (
            <div
              class="scroll-reveal flex items-start gap-3 bg-white rounded-2xl p-5 shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-xl hover:border-purple-200 hover:-translate-y-2 cursor-pointer group"
              style={`animation-range: entry 0% entry ${60 + index * 15}%;`}
            >
              <div class="grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-pink-50 text-pink-600 transition-transform duration-300 group-hover:scale-110">
                <Icon name={prop.icon} class="w-5 h-5" />
              </div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1 group-hover:text-purple-600 transition-colors">{prop.title}</h3>
                <p class="text-sm text-gray-600">{prop.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center z-10">
      <h2 class="scroll-reveal text-2xl md:text-4xl font-bold text-gray-900 mb-3">Ready to see Shiksit platform in your institution?</h2>
      <p class="scroll-reveal text-gray-600 mb-6 max-w-xl mx-auto" style="animation-range: entry 0% entry 75%;">
        Request a personalized demo tailored to your educational institution.
      </p>
      <div class="flex flex-row items-center justify-center gap-3">
        <button
          type="button"
          data-open-book-demo
          class="scroll-reveal inline-flex items-center justify-center gap-2 w-auto px-4 py-2 sm:px-8 sm:py-3 text-sm sm:text-base rounded-lg bg-blue-600 text-white font-semibold shadow-sm hover:bg-blue-700 transition-colors"
          style="animation-range: entry 0% entry 90%;"
        >
          Book Demo
          <span aria-hidden="true">→</span>
        </button>
        <a
          href="/offerings"
          class="scroll-reveal inline-flex items-center justify-center gap-2 w-auto px-4 py-2 sm:px-8 sm:py-3 text-sm sm:text-base rounded-lg border border-gray-300 bg-gray-100 text-gray-800 font-semibold hover:bg-gray-200 hover:border-purple-400 hover:text-purple-600 transition-colors"
          style="animation-range: entry 0% entry 90%;"
        >
          View Offerings
        </a>
      </div>
    </section>
  </div>
</Layout>

<script>
  // ── Entrance animations ──────────────────────────────────────────────────
  const show = (id: string) => {
    const el = document.getElementById(id);
    if (el) {
      el.classList.remove("opacity-0", "translate-y-4");
    }
  };

  // Trigger after first paint so CSS transitions fire
  requestAnimationFrame(() => {
    show("hero-badge");
    show("hero-heading");
    show("hero-body");
    show("hero-video");
  });

  // ── Parallax on scroll ───────────────────────────────────────────────────
  const blobs = document.querySelectorAll<HTMLElement>(".hero-blob > div");

  window.addEventListener("scroll", () => {
    const y = window.scrollY;
    blobs.forEach((blob, i) => {
      blob.style.transform = `translateY(${y * (0.06 + i * 0.04)}px)`;
    });
  }, { passive: true });
</script>
