---
import Layout from "../layouts/Layout.astro";
import { LINKS } from "../consts";

const roleHighlights = [
  { emoji: "👩‍🏫", title: "Teachers", bg: "bg-yellow-100", description: "Automated grading, lesson planning, and full class management in one dashboard." },
  { emoji: "🎒", title: "Students", bg: "bg-green-100", description: "Assignments, interactive lessons, and progress tracking, built for engagement." },
  { emoji: "🏠", title: "Parents", bg: "bg-blue-100", description: "Real-time attendance, grades, and direct messaging with teachers." },
  { emoji: "🎓", title: "Principals", bg: "bg-purple-100", description: "Institution-wide oversight — enrollment, staff, and performance at a glance." },
  { emoji: "💰", title: "Finance Admins", bg: "bg-teal-100", description: "Fee collection, invoicing, and financial reporting, fully in-platform." },
  { emoji: "🚌", title: "Transport Admins", bg: "bg-orange-100", description: "Routes, vehicles, and pickup/drop tracking for student transport." },
  { emoji: "🧑‍💼", title: "Counselors", bg: "bg-pink-100", description: "Behavioral tracking and well-being monitoring to support every student." },
  { emoji: "💡", title: "IT Admins", bg: "bg-indigo-100", description: "User provisioning, access control, and platform settings, centralized." },
];

const valueProps = [
  { icon: "💵", title: "Fixed Monthly Pricing", description: "Simple monthly billing with no hidden fees, scaled to your institution size." },
  { icon: "💬", title: "Parent Communication", description: "Keep parents engaged and updated in real time about assignments and marks." },
  { icon: "✨", title: "Assisted Onboarding", description: "Complete setup support and interactive tutorials for all administrative staff." },
];
---

<Layout>
  <div class="relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-[500px] bg-gradient-to-b from-purple-50/50 via-pink-50/10 to-transparent pointer-events-none z-0"></div>

    <section class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12 text-center z-10">
      <span class="inline-flex items-center gap-1.5 bg-purple-100 text-purple-700 font-bold text-xs py-1 px-3.5 rounded-full mb-4 shadow-sm">
        ✨ Built for Academic Institutions
      </span>

      <h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 leading-tight tracking-tight max-w-4xl mx-auto mb-4">
        One Platform for Educators, Administrators, Learners, and Families
      </h1>

      <p class="text-base md:text-xl text-gray-600 max-w-2xl mx-auto mb-10 leading-relaxed font-medium">
        Shiksit brings attendance, grading, communication, and finance into one unified platform for
        schools, colleges, and learning centers — built to scale as your institution grows.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={LINKS.freeTrial}
          class="px-6 py-3 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 text-white font-semibold shadow-sm hover:opacity-90 transition-opacity inline-flex items-center justify-center gap-2"
        >
          Start Free Trial
          <span aria-hidden="true">→</span>
        </a>
        <a
          href={LINKS.pricing}
          class="px-6 py-3 rounded-lg border border-gray-300 text-gray-700 font-semibold hover:bg-gray-50 transition-colors"
        >
          See Pricing
        </a>
      </div>
    </section>

    <section id="features" class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 z-10">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 text-center mb-2">Built for every role in your school</h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-10">
        Every dashboard is purpose-built for the person using it — no clutter, no learning curve.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {roleHighlights.map((role) => (
          <div class={`${role.bg} rounded-2xl p-5`}>
            <div class="text-3xl mb-3">{role.emoji}</div>
            <h3 class="font-bold text-gray-900 mb-1">{role.title}</h3>
            <p class="text-sm text-gray-700">{role.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="relative bg-gray-50 py-16 z-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 text-center mb-10">Why schools choose Shiksit</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {valueProps.map((prop) => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
              <div class="text-3xl mb-3">{prop.icon}</div>
              <h3 class="font-bold text-gray-900 mb-2">{prop.title}</h3>
              <p class="text-sm text-gray-600">{prop.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center z-10">
      <h2 class="text-2xl md:text-4xl font-bold text-gray-900 mb-4">Ready to see Shiksit in your school?</h2>
      <p class="text-gray-600 mb-8 max-w-xl mx-auto">
        Spin up a sample school in one click, or provision a demo tailored to your institution — an admin
        reviews and approves every request.
      </p>
      <a
        href={LINKS.freeTrial}
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 text-white font-semibold shadow-sm hover:opacity-90 transition-opacity"
      >
        Start Free Trial
        <span aria-hidden="true">→</span>
      </a>
    </section>
  </div>
</Layout>
